      "key": "ABOUT_LABEL",
      "value": "Our Story"
    },
    {
      "key": "ABOUT_HEADLINE",
      "value": "Preserving Authentic Flavors"
    },
    {
      "key": "ABOUT_PARA_1",
      "value": "MANA Desi-Licious was born from a deep passion to preserve and share the authentic, time-honored flavors of South India. What started as a small family kitchen cooking traditional generational recipes has grown into a space dedicated to bringing the taste of home to your table."
    },
    {
      "key": "ABOUT_PARA_2",
      "value": "Every carefully crafted sweet and savory snack uses only the finest natural ingredients, completely free from preservatives. Our mission is simple: honest, pure, and authentic taste in every bite."
    },
    {
      "key": "ABOUT_IMAGE",
      "value": "/images/sunnundalu.png"
    },
    {
      "key": "FEATURE_1_TITLE",
      "value": "Heritage and Recipes"
    },
    {
      "key": "FEATURE_1_DESC",
      "value": "Sourced directly from generational family kitchens for true authenticity."
    },
    {
      "key": "FEATURE_2_TITLE",
      "value": "Purity Guaranteed"
    },
    {
      "key": "FEATURE_2_DESC",
      "value": "No artificial colors, no preservatives. Just 100% natural goodness."
    },
    {
      "key": "FEATURE_3_TITLE",
      "value": "Freshly Made"
    },
    {
      "key": "FEATURE_3_DESC",
      "value": "Small-batch preparation ensures every order is as fresh as home-cooked food."
    },
    {
      "key": "FOOTER_TEXT",
      "value": "Taste the Tradition of India in Every Bite."
    },
